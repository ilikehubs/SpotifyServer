# ── Server ──────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# Production: your cloudflared subdomain (no trailing slash)
# Dev: http://localhost:5173
FRONTEND_URL=https://spotify.yourdomain.com

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-in-production

# ── Spotify ──────────────────────────────────────────────
# Dashboard: https://developer.spotify.com/dashboard
# Add redirect URI: https://spotify.yourdomain.com/api/auth/callback
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=https://spotify.yourdomain.com/api/auth/callback

# ── Setlist.fm ───────────────────────────────────────────
# https://www.setlist.fm/settings/apps
SETLISTFM_API_KEY=your_setlistfm_api_key
